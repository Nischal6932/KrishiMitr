# Smart Farming Assistant - Environment Variables
# Copy this file to .env and fill in your actual values

# Required: Groq API Key for AI functionality
GROQ_API_KEY=your_groq_api_key_here

# Flask Configuration
FLASK_DEBUG=False
PORT=10000
ENVIRONMENT=production
SECRET_KEY=replace_with_a_long_random_secret
ENABLE_PROXY_FIX=True
CORS_ORIGINS=*
PRELOAD_MODEL=False

# Optional: Model Configuration
MODEL_PATH=plant_disease_realworld_15class_best_v4.keras
GITHUB_MODEL_URL=https://github.com/Nischal6932/No_Ollama/releases/download/v1.0/plant_disease_realworld_15class_best_v4.keras

# Optional: AWS S3 (for cloud model storage)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_BUCKET_NAME=your_bucket_name
# AWS_REGION=us-east-1

# Optional: Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=smart_farming.log
